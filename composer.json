{
    "name": "verbaguard/verbaguard",
    "description": "Framework-independent PHP reference implementation for language-aware text moderation",
    "type": "library",
    "license": "MIT",
    "keywords": ["profanity", "moderation", "text-filter", "turkish", "language-aware"],
    "authors": [
        {
            "name": "VerbaGuard Contributors"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "VerbaGuard\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VerbaGuard\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "pest"
    },
    "minimum-stability": "stable"
}
