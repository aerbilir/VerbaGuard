{
    "name": "verbaguard/verbaguard",
    "description": "Framework-independent PHP reference implementation for language-aware text moderation",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "profanity",
        "moderation",
        "text-filter",
        "text-moderation",
        "content-moderation",
        "turkish",
        "language-aware",
        "php"
    ],
    "homepage": "https://github.com/aerbilir/VerbaGuard",
    "authors": [
        {
            "name": "VerbaGuard Contributors"
        }
    ],
    "support": {
        "issues": "https://github.com/aerbilir/VerbaGuard/issues",
        "source": "https://github.com/aerbilir/VerbaGuard"
    },
    "require": {
        "php": "^8.2",
        "ext-mbstring": "*"
    },
    "suggest": {
        "ext-intl": "Enables Unicode NFC normalization for more consistent matching"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "VerbaGuard\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VerbaGuard\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "minimum-stability": "stable",
    "archive": {
        "exclude": [
            "/.github",
            "/tests",
            "/.cursor",
            "/graphify-out"
        ]
    }
}
